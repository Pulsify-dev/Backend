{
  "info": {
    "name": "Module 6 - Engagement & Social Interactions",
    "description": "API collection for likes, reposts, and timestamped comments. Likes and reposts now support both tracks and albums, while comments remain track-only.",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variables": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/v1"
    },
    {
      "key": "accessToken",
      "value": "YOUR_ACCESS_TOKEN_HERE"
    },
    {
      "key": "trackId",
      "value": "65d8f7b2c1a2b3c4d5e6f7g8"
    },
    {
      "key": "albumId",
      "value": "65d8f7b2c1a2b3c4d5e6f7a9"
    },
    {
      "key": "commentId",
      "value": "65d8f7b2c1a2b3c4d5e6f7c1"
    }
  ],
  "item": [
    {
      "name": "LIKES",
      "item": [
        {
          "name": "Like a Track",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tracks/{{trackId}}/like",
              "host": ["{{baseUrl}}"],
              "path": ["tracks", "{{trackId}}", "like"]
            },
            "description": "Like a track (one-tap action)"
          },
          "response": []
        },
        {
          "name": "Unlike a Track",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tracks/{{trackId}}/like",
              "host": ["{{baseUrl}}"],
              "path": ["tracks", "{{trackId}}", "like"]
            },
            "description": "Remove like from a track"
          },
          "response": []
        },
        {
          "name": "Get Track's Likers (Engagement List)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tracks/{{trackId}}/likes?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["tracks", "{{trackId}}", "likes"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "Get paginated list of users who liked this track"
          },
          "response": []
        },
        {
          "name": "Check if User Liked Track",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tracks/{{trackId}}/liked",
              "host": ["{{baseUrl}}"],
              "path": ["tracks", "{{trackId}}", "liked"]
            },
            "description": "Check if current user has liked this track"
          },
          "response": []
        },
        {
          "name": "Like an Album",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/albums/{{albumId}}/like",
              "host": ["{{baseUrl}}"],
              "path": ["albums", "{{albumId}}", "like"]
            },
          "description": "Like an album. Album likes are stored separately and do not add anything to the track Likes playlist."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "cookie": [],
              "body": "{\n    \"message\": \"Album liked successfully.\"\n}"
            },
            {
              "name": "409 Conflict - Already Liked",
              "status": "Conflict",
              "code": 409,
              "_postman_previewlanguage": "json",
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "cookie": [],
              "body": "{\n    \"error\": \"You have already liked this album.\"\n}"
            }
          ]
        },
        {
          "name": "Unlike an Album",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/albums/{{albumId}}/like",
              "host": ["{{baseUrl}}"],
              "path": ["albums", "{{albumId}}", "like"]
            },
          "description": "Remove like from an album"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "cookie": [],
              "body": "{\n    \"message\": \"Album unliked successfully.\"\n}"
            }
          ]
        },
        {
          "name": "Get Album's Likers (Engagement List)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/albums/{{albumId}}/likes?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["albums", "{{albumId}}", "likes"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
          "description": "Get paginated list of users who liked this album"
