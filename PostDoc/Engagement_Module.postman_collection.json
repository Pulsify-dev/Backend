          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "cookie": [],
              "body": "{\n    \"album_id\": \"65d8f7b2c1a2b3c4d5e6f7a9\",\n    \"likes_count\": 3,\n    \"likers\": [\n        {\n            \"user_id\": \"69ceb4dac65280182638c8cb\",\n            \"username\": \"username\",\n            \"display_name\": \"username\",\n            \"avatar_url\": \"https://pulsify-s3-dev.s3.eu-central-1.amazonaws.com/users/avatars/1775605627700_avatar.jpg\",\n            \"liked_at\": \"2026-04-14T15:30:00.000Z\"\n        }\n    ],\n    \"pagination\": {\n        \"page\": 1,\n        \"limit\": 20,\n        \"total\": 1,\n        \"pages\": 1\n    }\n}"
            }
          ]
        },
        {
          "name": "Check if User Liked Album",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/albums/{{albumId}}/liked",
              "host": ["{{baseUrl}}"],
              "path": ["albums", "{{albumId}}", "liked"]
            },
          "description": "Check if current user has liked this album"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "cookie": [],
              "body": "{\n    \"album_id\": \"65d8f7b2c1a2b3c4d5e6f7a9\",\n    \"liked\": true\n}"
            }
          ]
        }
      ]
    },
