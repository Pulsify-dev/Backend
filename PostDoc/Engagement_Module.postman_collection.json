    {
      "name": "COMMENTS",
      "item": [
        {
          "name": "Create a Comment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Love this drop at 1:30!\",\n  \"timestamp_seconds\": 90\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tracks/{{trackId}}/comments",
              "host": ["{{baseUrl}}"],
              "path": ["tracks", "{{trackId}}", "comments"]
            },
            "description": "Leave a timestamped comment on a track"
          },
          "response": []
        },
        {
          "name": "Create a Comment Reply",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"I completely agree!\",\n  \"timestamp_seconds\": 90,\n  \"parent_comment_id\": \"{{commentId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tracks/{{trackId}}/comments",
              "host": ["{{baseUrl}}"],
              "path": ["tracks", "{{trackId}}", "comments"]
            },
            "description": "Reply to a comment (include parent_comment_id)"
          },
          "response": []
        },
        {
          "name": "Update a Comment",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Updated: Even better on second listen!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/comments/{{commentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["comments", "{{commentId}}"]
            },
            "description": "Edit your own comment"
          },
          "response": []
        },
        {
          "name": "Delete a Comment",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/comments/{{commentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["comments", "{{commentId}}"]
            },
            "description": "Delete your own comment (soft delete)"
          },
          "response": []
        },
        {
          "name": "Get All Comments on Track",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tracks/{{trackId}}/comments?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["tracks", "{{trackId}}", "comments"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "Get paginated comments on a track (sorted by timestamp)"
          },
          "response": []
        },
