          "host": ["{{baseUrl}}"],
          "path": ["users"],
          "query": [
            { "key": "q", "value": "test" },
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "20" }
          ]
        },
        "description": "## 9. Search Users\n\nSearches public profiles by username or display name. Private, suspended, and blocked users are excluded from results.\n\n**Authentication:** Not required\n\n### Query Parameters\n\n| Parameter | Type | Default | Description |\n|-----------|------|---------|-------------|\n| `q` | String | - | Search query (matches username and display_name). |\n| `page` | Number | `1` | Pagination page. |\n| `limit` | Number | `20` | Results per page (max 100). |"
      },
      "response": [
        {
          "name": "200 OK – Results Found",
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
