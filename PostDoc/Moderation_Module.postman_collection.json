            {
              "key": "id",
              "value": "64f1a2b3c4d5e6f7a8b9c0d1"
            }
          ]
        },
        "description": "Permanently deletes an album and its S3 artwork."
      }
    },
    {
      "name": "12. Update User Role (Admin)",
      "request": {
