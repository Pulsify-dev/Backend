                  "pm.test(\"Status is 400 Bad Request\", () => {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"display_name\": \"This is a very long display name that definitely exceeds fifty characters\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/users/me",
              "host": ["{{BASE_URL}}"],
              "path": ["users", "me"]
            },
            "description": "Test: Joi catches display_name > 50 characters\nExpected: 400 Bad Request"
          },
